# =============================================================================
# Content Provider Configuration
# =============================================================================
# Set to 'static' for static generation or 'directus' for Directus CMS
CMS_PROVIDER=static
PUBLIC_CMS_PROVIDER=static

# =============================================================================
# Site URL (REQUIRED for production — used in CSP, robots.txt, sitemaps, RSS)
# =============================================================================
PUBLIC_SITE_URL=http://localhost:8701

# =============================================================================
# Directus Configuration (only needed when CMS_PROVIDER=directus)
# =============================================================================
# IMPORTANT: These MUST be overridden in production. localhost defaults will
# break CSP headers and asset loading in deployed environments.
PUBLIC_DIRECTUS_URL=http://localhost:8701
DIRECTUS_URL=http://localhost:8701
DIRECTUS_TOKEN=
PUBLIC_ENABLE_VISUAL_EDITING=false

# Draft mode secret — used to preview unpublished posts. Use a strong random value in production.
DRAFT_MODE_SECRET=

# =============================================================================
# Logger Configuration (optional)
# =============================================================================
# APP_LOG_LEVEL=3        # 0=silent, 1=error, 2=warn, 3=info (default), 4=debug, 5=trace
# APP_LOGGER_DISABLED=false
